ninja_required_version = 1.3
cxx = c++
nvcc = /home/ubuntu/anaconda3/envs/Deep-MIST/bin/nvcc

cflags = -pthread -B /home/ubuntu/anaconda3/envs/Deep-MIST/compiler_compat -Wl,--sysroot=/ -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -DWITH_CUDA -I/home/ubuntu/data/zhengqinxu/object_detection/Deep-MIST/deepmist/models/multiframe/RFR/dcn/src -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include/TH -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include/THC -I/home/ubuntu/anaconda3/envs/Deep-MIST/include -I/home/ubuntu/anaconda3/envs/Deep-MIST/include/python3.8 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=DCN2 -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -DWITH_CUDA -I/home/ubuntu/data/zhengqinxu/object_detection/Deep-MIST/deepmist/models/multiframe/RFR/dcn/src -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include/torch/csrc/api/include -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include/TH -I/home/ubuntu/anaconda3/envs/Deep-MIST/lib/python3.8/site-packages/torch/include/THC -I/home/ubuntu/anaconda3/envs/Deep-MIST/include -I/home/ubuntu/anaconda3/envs/Deep-MIST/include/python3.8 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DCUDA_HAS_FP16=1 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=DCN2 -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_89,code=compute_89 -gencode=arch=compute_89,code=sm_89 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





